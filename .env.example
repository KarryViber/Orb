# Slack App credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code CLI path (default: claude)
# CLAUDE_PATH=claude

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Max agent turns per task (default: 50)
# MAX_TURNS=50

# Max concurrent worker processes (default: 2)
# MAX_WORKERS=2

# Holographic memory (optional, requires Python + lib/holographic)
# MEMORY_ENABLED=true
# PYTHON_PATH=python3

# Slack behavior
# REPLY_BROADCAST=false
