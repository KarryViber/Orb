# Slack App credentials (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Claude Code CLI path (default: claude)
# CLAUDE_PATH=claude

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# Claude CLI effort (low / medium / high / xhigh / max)
# CLAUDE_EFFORT=low

# Max agent turns per task (default: 50)
# MAX_TURNS=50

# Worker single-turn timeout in ms (default 1800000 = 30 min)
# ORB_WORKER_TIMEOUT_MS=1800000

# Override worker workspace directory (default: profile workspaceDir or cwd)
# WORKSPACE_DIR=

# Slack image cache directory
# IMAGE_CACHE_DIR=

# Holographic memory (optional, requires Python + lib/holographic)
# MEMORY_ENABLED=true
# PYTHON_PATH=python3

# Memory recall tuning (defaults: 10 / 0.3 / 8)
# ORB_MEMORY_RECALL_LIMIT — how many facts recallMemory returns
# ORB_MEMORY_MIN_TRUST    — minimum trust_score to include (0.0 = include all)
# ORB_DOC_RECALL_LIMIT    — how many doc chunks searchDocs returns (0 = disable)
# ORB_MEMORY_RECALL_LIMIT=10
# ORB_MEMORY_MIN_TRUST=0.3
# ORB_DOC_RECALL_LIMIT=8

# Memory arbitration (write-time LLM curation via claude CLI)
# MEMORY_ARBITRATE=true              # set false to skip arbitration entirely
# MEMORY_ARBITRATE_MODEL=haiku       # haiku / sonnet / opus
# MEMORY_ARBITRATE_TIMEOUT_SEC=15    # fall back to ADD on timeout

# DocStore (file index for holographic recall)
# DOC_INDEX_ENABLED=true
# DOC_REGISTRY_PATH=
# DOC_PROJECTS_ROOT=
# DOC_INDEX_DB=
